PORT=5001
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/your_db_name
JWT_SECRET=your_super_secret_jwt_key
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
FRONTEND_URL=https://your-hostinger-domain.com
NODE_ENV=production
# Add other variables if needed (e.g., SMTP for email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@your-verified-domain.com

# Recharge provider
INSPAY_USERNAME=your_inspay_username
INSPAY_TOKEN=your_inspay_token
INSPAY_FETCH_USERNAME=your_plan_fetch_username
INSPAY_FETCH_PLANS_TOKEN=your_plan_fetch_token
INSPAY_API_URL=https://www.connect.inspay.in/v3/recharge/api
INSPAY_BALANCE_URL=https://www.connect.inspay.in/v3/recharge/balance
INSPAY_STATUS_URL=https://www.connect.inspay.in/v3/recharge/status

# Optional provider URLs (if different from defaults in config)
EKYCHUB_PLAN_API_URL=https://connect.ekychub.in/v3/verification/operator_plan_fetch
EKYCHUB_OPERATOR_FETCH_API_URL=https://connect.ekychub.in/v3/verification/operator_fetch
